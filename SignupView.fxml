<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mediaplayer.controller.SignupController" alignment="CENTER" spacing="20.0" style="-fx-background-color: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);">
   <children>
      <Label text="Media Player Sign Up" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets top="40.0" />
         </VBox.margin>
      </Label>
      <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 10; -fx-padding: 20;">
         <children>
            <Label text="Name:" textFill="WHITE" />
            <TextField fx:id="nameField" promptText="Enter your name" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: white; -fx-prompt-text-fill: rgba(255, 255, 255, 0.7);" />
            <Label text="Email:" textFill="WHITE" />
            <TextField fx:id="emailField" promptText="Enter your email" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: white; -fx-prompt-text-fill: rgba(255, 255, 255, 0.7);" />
            <Label text="Password:" textFill="WHITE" />
            <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: white; -fx-prompt-text-fill: rgba(255, 255, 255, 0.7);" />
         </children>
      </VBox>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button fx:id="registerButton" onAction="#handleRegister" text="Register" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20 10 20;" />
            <Button fx:id="backButton" onAction="#handleBack" text="Back to Login" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20 10 20;" />
         </children>
      </HBox>
      <Label fx:id="messageLabel" textFill="WHITE" />
   </children>
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
</VBox>
